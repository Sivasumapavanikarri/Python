import sys
input = sys.stdin.readline

T = int(input())

for _ in range(T):
    N = int(input())
    arr = list(map(int, input().split()))
    
    if N < 2:
        print("UNFIT")
        continue
    
    min_so_far = arr[0]
    max_diff = 0
    
    for i in range(1, N):
        if arr[i] > min_so_far:
            max_diff = max(max_diff, arr[i] - min_so_far)
        else:
            min_so_far = arr[i]
    
    if max_diff > 0:
        print(max_diff)
    else:
        print("UNFIT")
